<section id="contact" class="relative py-24">
  <!-- Animated emerald gradient blob behind the card -->
  <div class="contact-blob absolute inset-0 -z-10 overflow-hidden" aria-hidden="true">
    <div class="contact-blob-inner"></div>
  </div>

  <div class="mx-auto max-w-5xl px-6">
    <div id="contact-card" class="contact-card fade-in relative mx-auto max-w-2xl">
      <div class="contact-glow" aria-hidden="true"></div>
      <div class="section-card section-card--static relative z-10 rounded-2xl p-8 sm:p-12">

      <!-- Form view -->
      <div id="contact-form-view">
        <h2 class="mb-3 text-center font-mono text-xl font-bold text-[#1a1a1a] sm:text-2xl dark:text-white">
          Get in Touch
        </h2>
        <p class="mb-8 text-center text-gray-500 dark:text-gray-400">
          Have a project idea, a question, or just want to connect? Drop me a message.
        </p>

        <form action="/api/contact" method="POST" novalidate class="flex flex-col gap-5">
          <!-- Honeypot: hidden from real users, bots fill it in -->
          <input type="text" name="website" class="hidden" tabindex="-1" autocomplete="off" aria-label="Leave this field empty" />

          <div>
            <label for="name" class="mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300">Name</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              minlength="2"
              autocomplete="name"
              placeholder="Your name"
              class="contact-input w-full rounded-lg border border-gray-200 bg-white/80 px-4 py-2.5 text-sm text-[#1a1a1a] placeholder-gray-500 outline-none transition-all dark:border-white/10 dark:bg-white/5 dark:text-white dark:placeholder-gray-500"
            />
            <p class="field-hint" data-for="name"></p>
          </div>

          <div>
            <label for="email" class="mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300">E-Mail</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              autocomplete="email"
              placeholder="you@example.com"
              class="contact-input w-full rounded-lg border border-gray-200 bg-white/80 px-4 py-2.5 text-sm text-[#1a1a1a] placeholder-gray-500 outline-none transition-all dark:border-white/10 dark:bg-white/5 dark:text-white dark:placeholder-gray-500"
            />
            <p class="field-hint" data-for="email"></p>
          </div>

          <div>
            <label for="message" class="mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300">Message</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              required
              minlength="10"
              autocomplete="off"
              placeholder="Your message..."
              class="contact-input w-full resize-none rounded-lg border border-gray-200 bg-white/80 px-4 py-2.5 text-sm text-[#1a1a1a] placeholder-gray-500 outline-none transition-all dark:border-white/10 dark:bg-white/5 dark:text-white dark:placeholder-gray-500"
            ></textarea>
            <p class="field-hint" data-for="message"></p>
          </div>

          <!-- Cloudflare Turnstile Widget (rendered explicitly on submit) -->
          <div id="turnstile-container" class="hidden" data-sitekey="0x4AAAAAAChqv4YCfiRUPj3O" aria-label="CAPTCHA verification"></div>

          <button
            type="submit"
            class="btn-primary mt-2 inline-flex h-[44px] w-[140px] items-center justify-center rounded-lg text-sm"
          >
            Send Message
          </button>
        </form>
      </div>

      <!-- Success view (hidden by default) -->
      <div id="contact-success-view" class="hidden py-12 text-center">
        <div class="mb-4 inline-flex h-16 w-16 items-center justify-center rounded-full bg-emerald-500/10">
          <svg class="h-8 w-8 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h3 class="mb-3 font-mono text-lg font-bold text-emerald-600 dark:text-emerald-400">200 OK</h3>
        <p class="mx-auto mb-6 max-w-md font-mono text-sm leading-relaxed text-gray-500 dark:text-gray-400">
          Request received. Your message has been containerized and is queued for review. I'll ping you back soon.
        </p>
        <button
          id="contact-send-another"
          class="font-mono text-sm text-emerald-600 transition-colors hover:text-emerald-500 dark:text-emerald-400 dark:hover:text-emerald-300"
        >
          Send another message
        </button>
      </div>

      </div>
    </div>
  </div>
</section>

<style>
  /* Animated background blob */
  .contact-blob-inner {
    position: absolute;
    width: 600px;
    height: 600px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background: radial-gradient(circle, rgba(5, 150, 105, 0.1) 0%, transparent 70%);
    animation: contact-drift 20s infinite alternate ease-in-out;
  }

  @keyframes contact-drift {
    0% {
      transform: translate(-50%, -50%) translate(-40px, 30px);
    }
    33% {
      transform: translate(-50%, -50%) translate(30px, -20px);
    }
    66% {
      transform: translate(-50%, -50%) translate(-20px, -30px);
    }
    100% {
      transform: translate(-50%, -50%) translate(40px, 20px);
    }
  }

  /* Input focus glow */
  .contact-input:focus {
    border-color: #10b981;
    box-shadow: 0 0 0 3px rgba(5, 150, 105, 0.15);
  }

  /* Validation hint text */
  .field-hint {
    min-height: 0;
    max-height: 0;
    overflow: hidden;
    margin: 0;
    padding: 0;
    font-size: 0.75rem;
    line-height: 1.4;
    opacity: 0;
    transition: max-height 0.25s ease, opacity 0.25s ease, margin 0.25s ease;
  }

  .field-hint.visible {
    max-height: 2em;
    opacity: 1;
    margin-top: 0.375rem;
  }

  /* Moving border glow on typing */
  .contact-glow {
    position: absolute;
    inset: -3px;
    z-index: 0;
    border-radius: 1.1rem;
    opacity: 0;
    transition: opacity 0.8s ease;
    overflow: hidden;
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    padding: 3px;
  }

  .contact-glow::before {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    width: 200%;
    height: 200%;
    margin-left: -100%;
    margin-top: -100%;
    background: conic-gradient(
      from 0deg,
      transparent 0%,
      transparent 15%,
      rgba(5, 150, 105, 0.5) 25%,
      rgba(5, 150, 105, 0.6) 30%,
      rgba(5, 150, 105, 0.5) 35%,
      transparent 45%,
      transparent 100%
    );
    animation: contact-glow-rotate 8s linear infinite;
  }

  .contact-card.is-typing .contact-glow {
    opacity: 1;
  }

  /* Disable section-card hover glow while typing glow is active */
  .contact-card.is-typing .section-card {
    border-color: transparent !important;
    box-shadow: none !important;
  }

  @keyframes contact-glow-rotate {
    to {
      transform: rotate(360deg);
    }
  }

  /* Submit button lift on hover */
  .contact-submit {
    box-shadow: 0 2px 8px rgba(5, 150, 105, 0.2);
  }

  .contact-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(5, 150, 105, 0.3);
  }

  /* Loading dots bounce animation */
  .loading-dots {
    display: inline-flex;
    gap: 3px;
    margin-left: 4px;
    vertical-align: middle;
  }

  .loading-dots span {
    display: inline-block;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background-color: currentColor;
    animation: dot-bounce 1.2s ease-in-out infinite;
  }

  .loading-dots span:nth-child(2) {
    animation-delay: 0.15s;
  }

  .loading-dots span:nth-child(3) {
    animation-delay: 0.3s;
  }

  @keyframes dot-bounce {
    0%, 60%, 100% {
      transform: translateY(0);
      opacity: 0.4;
    }
    30% {
      transform: translateY(-5px);
      opacity: 1;
    }
  }
</style>

<script>
  declare global {
    interface Window {
      turnstile: {
        render: (container: HTMLElement | string, options: Record<string, unknown>) => string;
        execute: (container: HTMLElement | string | null, options?: Record<string, unknown>) => void;
        remove: (widgetId: string) => void;
        reset: (widgetId?: string) => void;
      };
    }
  }

  const form = document.querySelector<HTMLFormElement>("#contact form");
  const container = document.getElementById("turnstile-container");
  const card = document.getElementById("contact-card");
  const formView = document.getElementById("contact-form-view");
  const successView = document.getElementById("contact-success-view");
  const sendAnother = document.getElementById("contact-send-another");
  let turnstileReady = false;
  let turnstileWidgetId: string | null = null;

  const sitekey = container?.dataset.sitekey ?? "";

  // ── Field hint helpers ──
  const hints = new Map<string, HTMLParagraphElement>();
  form?.querySelectorAll<HTMLParagraphElement>(".field-hint").forEach((el) => {
    const fieldName = el.dataset.for;
    if (fieldName) hints.set(fieldName, el);
  });

  function showHint(fieldName: string, message: string) {
    const el = hints.get(fieldName);
    if (!el) return;
    el.textContent = message;
    el.style.color = document.documentElement.classList.contains("dark")
      ? "rgba(255, 255, 255, 0.45)"
      : "rgba(0, 0, 0, 0.45)";
    el.classList.add("visible");
  }

  function clearHint(fieldName: string) {
    const el = hints.get(fieldName);
    if (!el) return;
    el.classList.remove("visible");
  }

  function clearAllHints() {
    hints.forEach((_, name) => clearHint(name));
  }

  function validateField(field: HTMLInputElement | HTMLTextAreaElement): boolean {
    const name = field.name;
    const value = field.value.trim();

    // Required check
    if (field.hasAttribute("required") && !value) {
      showHint(name, "Please fill out this field");
      return false;
    }

    // Email format
    if (field.type === "email" && value) {
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!emailRegex.test(value)) {
        showHint(name, "Please enter a valid email address");
        return false;
      }
    }

    // Minlength
    const minLen = field.getAttribute("minlength");
    if (minLen && value.length > 0 && value.length < parseInt(minLen)) {
      showHint(name, `At least ${minLen} characters needed`);
      return false;
    }

    clearHint(name);
    return true;
  }

  function validateAll(): boolean {
    if (!form) return false;
    let valid = true;
    const fields = form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>("input:not([type=hidden]):not([name=website]), textarea");
    fields.forEach((field) => {
      if (!validateField(field)) valid = false;
    });
    return valid;
  }

  // Validate on blur (after user leaves a field)
  form?.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>("input:not([type=hidden]):not([name=website]), textarea").forEach((field) => {
    field.addEventListener("blur", () => validateField(field));
    // Clear hint as user types valid content
    field.addEventListener("input", () => {
      if (field.value.trim()) validateField(field);
    });
  });

  function getTurnstileTheme(): "dark" | "light" {
    return document.documentElement.classList.contains("dark") ? "dark" : "light";
  }

  function renderTurnstile() {
    if (!container || !window.turnstile) return;

    turnstileWidgetId = window.turnstile.render(container, {
      sitekey,
      theme: getTurnstileTheme(),
      execution: "execute",
      callback: (token: string) => {
        // Inject token into form and auto-submit
        let tokenInput = form?.querySelector<HTMLInputElement>("[name='cf-turnstile-response']");
        if (!tokenInput) {
          tokenInput = document.createElement("input");
          tokenInput.type = "hidden";
          tokenInput.name = "cf-turnstile-response";
          form?.appendChild(tokenInput);
        }
        tokenInput.value = token;
        container?.classList.add("hidden");
        submitForm();
      },
      "error-callback": () => {
        showError("CAPTCHA verification failed. Please try again.");
        resetTurnstile();
        const btn = form?.querySelector<HTMLButtonElement>("button[type=submit]");
        if (btn) { btn.disabled = false; btn.innerHTML = "Send Message"; }
      },
    });

    // Trigger the challenge immediately after rendering
    window.turnstile.execute(container);
  }

  function resetTurnstile() {
    if (turnstileWidgetId) {
      window.turnstile.remove(turnstileWidgetId);
      turnstileWidgetId = null;
    }
    if (container) {
      container.innerHTML = "";
      container.classList.add("hidden");
    }
    turnstileReady = false;
  }

  // Re-render Turnstile when user switches theme (widget currently visible)
  window.addEventListener("theme-change", () => {
    if (!turnstileReady || !container || container.classList.contains("hidden")) return;
    container.innerHTML = "";
    turnstileWidgetId = null;
    renderTurnstile();
  });

  // Typing detection — activate glow, stays until submit
  form?.addEventListener("input", () => {
    card?.classList.add("is-typing");
  });

  // Send another message — reset to form view
  sendAnother?.addEventListener("click", () => {
    successView?.classList.add("hidden");
    formView?.classList.remove("hidden");
    clearAllHints();
  });

  async function submitForm() {
    if (!form) return;

    const btn = form.querySelector<HTMLButtonElement>("button[type=submit]");
    const dotsHTML = '<span class="loading-dots"><span></span><span></span><span></span></span>';
    if (btn) {
      btn.disabled = true;
      btn.innerHTML = `Sending${dotsHTML}`;
    }

    try {
      const res = await fetch(form.action, {
        method: "POST",
        body: new FormData(form),
      });

      if (res.ok) {
        form.reset();
        card?.classList.remove("is-typing");
        clearAllHints();
        // Show success view
        formView?.classList.add("hidden");
        successView?.classList.remove("hidden");
        // Fully destroy Turnstile widget so the used token is gone
        resetTurnstile();
      } else {
        const data = await res.json().catch(() => ({})) as { error?: string };
        showError(data.error || "Something went wrong. Please try again.");
      }
    } catch {
      showError("Network error. Please try again.");
    } finally {
      if (btn) {
        btn.disabled = false;
        btn.innerHTML = "Send Message";
      }
    }
  }

  function showError(msg: string) {
    // Show inline error below form
    let err = document.getElementById("contact-error");
    if (!err) {
      err = document.createElement("p");
      err.id = "contact-error";
      err.className = "mt-4 text-center text-sm";
      err.style.color = document.documentElement.classList.contains("dark")
        ? "rgba(255, 255, 255, 0.5)"
        : "rgba(0, 0, 0, 0.5)";
      form?.parentElement?.appendChild(err);
    }
    err.textContent = msg;

    // Auto-remove error after 5 seconds
    setTimeout(() => err?.remove(), 5000);
  }

  form?.addEventListener("submit", (e) => {
    e.preventDefault();

    // Custom validation — no browser popups
    if (!validateAll()) return;

    const btn = form.querySelector<HTMLButtonElement>("button[type=submit]");
    const dotsHTML = '<span class="loading-dots"><span></span><span></span><span></span></span>';
    if (btn) { btn.disabled = true; btn.innerHTML = `Verifying${dotsHTML}`; }

    // Render Turnstile widget and immediately execute the challenge.
    // The callback inside renderTurnstile() calls submitForm() on success.
    if (!turnstileReady) {
      container?.classList.remove("hidden");
      turnstileReady = true;
      renderTurnstile();
    }
    // If already rendered (e.g. error retry), re-execute the challenge
    else if (turnstileWidgetId) {
      window.turnstile.execute(container!);
    }
  });
</script>
