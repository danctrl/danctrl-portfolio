---
const projects = [
  {
    title: "danctrl.dev",
    description:
      "This website \u2013 built with Astro and Tailwind CSS, deployed on Cloudflare Pages with CI/CD. A meta-project showcasing DevOps thinking.",
    badge: "Live" as const,
    archived: false,
    image: "/portfolio_new.webp",
    imageAlt: "danctrl.dev portfolio website built with Astro and Tailwind CSS",
    stack: ["Astro", "Tailwind CSS", "Cloudflare Pages", "TypeScript"],
    link: "https://github.com/danctrl/danctrl-portfolio",
  },
  {
    title: "Homelab",
    description:
      "Lightweight homelab stack using Podman and systemd on RHEL. Containerized services with Traefik reverse proxy and Authentik authentication.",
    badge: "GitHub" as const,
    archived: false,
    image: "/homelab.webp",
    imageAlt: "Dashboard overview of a self-hosted Podman homelab on RHEL with Traefik reverse proxy",
    stack: ["Podman", "RHEL", "Traefik", "Systemd", "DevOps"],
    link: "https://github.com/danctrl/podman-containers",
  },
  {
    title: "Stadium",
    description:
      "Local-first Home Assistant instance running in a KVM virtual machine on RHEL. 409 entities, Zigbee/Matter integration, automated backups, secured with Traefik + Authentik.",
    badge: "GitHub" as const,
    archived: false,
    image: "/smarthome.webp",
    imageAlt: "Home Assistant smart home dashboard showing 409 entities and automation controls",
    stack: ["Home Assistant", "KVM", "Zigbee", "Matter", "YAML"],
    link: "https://github.com/danctrl/home-assistant-stadium",
  },
  {
    title: "Kita",
    description:
      "Web application helping parents in Berlin find and apply to kindergartens. Built during Le Wagon coding bootcamp as a team project.",
    badge: "GitHub" as const,
    archived: false,
    image: "/mykita.webp",
    imageAlt: "Web app helping Berlin parents find and apply to kindergartens",
    stack: ["Ruby on Rails", "PostgreSQL", "JavaScript", "Bootstrap"],
    link: "https://github.com/lamoureuxmarie/my-kita",
  },
  {
    title: "danctrl Legacy",
    description:
      "The original portfolio site \u2013 built with Hugo and deployed on Cloudflare Pages. Replaced by the current Astro-based version.",
    badge: "Live" as const,
    archived: true,
    image: "/portfolio_old.webp",
    imageAlt: "Original danctrl.dev portfolio site built with Hugo",
    stack: ["Hugo", "Go Templates", "Cloudflare Pages", "CI/CD"],
    link: "https://github.com/danctrl/danctrl.dev",
  },
];
---

<section id="projects" class="py-24">
  <div class="mx-auto max-w-5xl px-6">
    <div class="fade-in mb-12 flex items-center justify-between">
      <h2 class="font-mono text-xl font-bold text-[#1a1a1a] sm:text-2xl dark:text-white">Projects</h2>
      <button
        id="archive-toggle"
        class="group/switch inline-flex items-center gap-3 rounded-lg border border-black/5 bg-white/60 px-4 py-2 text-sm text-gray-600 backdrop-blur-xl transition-all duration-300 hover:border-emerald-500/50 hover:text-emerald-600 dark:border-white/10 dark:bg-white/5 dark:text-gray-400 dark:hover:border-emerald-500/50 dark:hover:text-emerald-400"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M3 3a1 1 0 011-1h16a1 1 0 011 1v3a1 1 0 01-1 1H4a1 1 0 01-1-1V3z" />
          <path fill-rule="evenodd" d="M3 8h18v11a2 2 0 01-2 2H5a2 2 0 01-2-2V8zm6 4a1 1 0 011-1h4a1 1 0 110 2h-4a1 1 0 01-1-1z" clip-rule="evenodd" />
        </svg>
        <span>Archive</span>
        <div class="relative h-5 w-9 rounded-full bg-gray-300 transition-colors duration-300 dark:bg-gray-600" id="switch-track">
          <div class="absolute top-0.5 left-0.5 h-4 w-4 rounded-full bg-white shadow transition-transform duration-300" id="switch-thumb"></div>
        </div>
      </button>
    </div>

    <div class="grid gap-6 sm:grid-cols-2">
      {projects.map((project, i) => {
        return (
          <a
            href={project.link}
            target="_blank"
            rel="noopener noreferrer"
            class:list={[
              "project-card section-card group relative block fade-in overflow-hidden",
              project.archived && "archive-card",
            ]}
            data-status={project.archived ? "archived" : "active"}
            style={project.archived ? "display: none;" : `transition-delay: ${i * 100}ms`}
          >
            {/* Thumbnail */}
            <div class="h-[200px] overflow-hidden bg-gray-100 dark:bg-white/5">
              <img src={project.image} alt={project.imageAlt} width="1280" height="640" loading={i === 0 ? "eager" : "lazy"} class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" />
            </div>

            <div class="p-6">
            {/* Header: title + badge */}
            <div class="mb-3 flex items-start justify-between gap-3">
              <h3 class="font-mono font-semibold text-[#1a1a1a] dark:text-white">
                {project.title}
              </h3>
              {project.badge === "Live" ? (
                <span class="inline-flex shrink-0 items-center gap-1.5 rounded-full bg-emerald-500/10 px-2.5 py-1 text-xs font-medium text-emerald-700 dark:bg-emerald-500/15 dark:text-emerald-400">
                  <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-emerald-500" />
                  Live
                </span>
              ) : (
                <span class="inline-flex shrink-0 items-center gap-1.5 rounded-full bg-gray-500/10 px-2.5 py-1 text-xs font-medium text-gray-600 dark:bg-white/10 dark:text-gray-400">
                  <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z" /></svg>
                  GitHub
                </span>
              )}
            </div>

            {/* Description */}
            <p class="mb-4 text-sm leading-relaxed text-gray-500 dark:text-gray-400">
              {project.description}
            </p>

            {/* Stack tags */}
            <div class="flex flex-wrap gap-2">
              {project.stack.map((tech) => (
                <span class="rounded-md bg-gray-100 px-2 py-0.5 font-mono text-xs text-gray-500 dark:bg-white/5 dark:text-gray-500">
                  {tech}
                </span>
              ))}
            </div>

            {/* External link indicator */}
            <div class="mt-4 text-right text-gray-400 opacity-0 transition-all duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 group-hover:text-emerald-500 group-hover:opacity-100 dark:text-gray-500 dark:group-hover:text-emerald-400">
              <svg class="inline" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M6 2h8v8M14 2L6 10" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>

<style>
  #archive-toggle.archive-active {
    border-color: rgba(16, 185, 129, 0.5);
    box-shadow: 0 0 12px rgba(16, 185, 129, 0.15);
    color: #059669;
  }

  :global(.dark) #archive-toggle.archive-active {
    color: #10b981;
  }
</style>

<script>
  const toggle = document.getElementById("archive-toggle");
  const track = document.getElementById("switch-track");
  const thumb = document.getElementById("switch-thumb");
  const activeCards = document.querySelectorAll<HTMLElement>('[data-status="active"]');
  const archiveCards = document.querySelectorAll<HTMLElement>('[data-status="archived"]');

  let isOpen = false;

  toggle?.addEventListener("click", () => {
    if (isOpen) {
      showActive();
    } else {
      showArchive();
    }
  });

  function setSwitchOn() {
    if (track) { track.style.backgroundColor = "#059669"; }
    if (thumb) { thumb.style.transform = "translateX(16px)"; }
    toggle?.classList.add("archive-active");
  }

  function setSwitchOff() {
    if (track) { track.style.backgroundColor = ""; }
    if (thumb) { thumb.style.transform = ""; }
    toggle?.classList.remove("archive-active");
  }

  function showArchive() {
    isOpen = true;
    setSwitchOn();

    // Fade out active cards
    activeCards.forEach((card) => {
      card.style.transition = "opacity 300ms ease-in, transform 300ms ease-in";
      card.style.opacity = "0";
      card.style.transform = "translateY(10px)";
    });

    setTimeout(() => {
      activeCards.forEach((card) => { card.style.display = "none"; });

      // Fade in archive cards
      archiveCards.forEach((card, i) => {
        card.style.display = "";
        card.style.opacity = "0";
        card.style.transform = "translateY(20px) scale(0.95)";
        card.style.transition = "none";

        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            card.style.transition = `opacity 500ms ease-out ${i * 150}ms, transform 500ms ease-out ${i * 150}ms`;
            card.style.opacity = "0.85";
            card.style.transform = "translateY(0) scale(1)";
          });
        });
      });
    }, 350);
  }

  function showActive() {
    isOpen = false;
    setSwitchOff();

    // Fade out archive cards
    const cards = Array.from(archiveCards).reverse();
    cards.forEach((card, i) => {
      card.style.transition = `opacity 300ms ease-in ${i * 150}ms, transform 300ms ease-in ${i * 150}ms`;
      card.style.opacity = "0";
      card.style.transform = "translateY(10px)";
    });

    const hideDelay = 300 + (cards.length - 1) * 150 + 50;
    setTimeout(() => {
      archiveCards.forEach((card) => {
        card.style.display = "none";
        card.style.transition = "none";
      });

      // Fade in active cards
      activeCards.forEach((card, i) => {
        card.style.display = "";
        card.style.opacity = "0";
        card.style.transform = "translateY(20px) scale(0.95)";
        card.style.transition = "none";

        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            card.style.transition = `opacity 500ms ease-out ${i * 150}ms, transform 500ms ease-out ${i * 150}ms`;
            card.style.opacity = "1";
            card.style.transform = "translateY(0) scale(1)";
          });
        });
      });
    }, hideDelay);
  }
</script>
